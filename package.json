{
  "name": "cassette",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "cfmt": "passable -i -q \"CMakeLists.txt\" \"cpp/**/CMakeLists.txt\" \"build/*.cmake\"",
    "format": "tools format bun && bun run cfmt",
    "fmt": "bun run format",
    "clean": "bun run build/clean.ts",
    "dcfg": "cmake --preset debug",
    "rcfg": "cmake --preset release",
    "cfg": "bun run dcfg",
    "dcpp": "cmake --build build/Debug",
    "rcpp": "cmake --build build/Release",
    "cpp": "bun run dcpp",
    "dwww": "bun run build/webbuild.ts Debug",
    "rwww": "bun run build/webbuild.ts Release",
    "www": "bun run dwww",
    "dbld": "bun run build/parbld.ts Debug",
    "rbld": "bun run build/parbld.ts Release",
    "bld": "bun run dbld",
    "dtst": "bun run dcpp && cd build/Debug && ctest --output-on-failure",
    "dtest": "bun run dcpp && cd build/Debug && ctest --output-on-failure",
    "rtst": "bun run rcpp && cd build/Release && ctest",
    "rtest": "bun run rcpp && cd build/Release && ctest",
    "tst": "bun run dtst",
    "test": "bun run dtst",
    "drun": "bun run os drun",
    "rrun": "bun run os rrun",
    "drun:win": "cmd /c build\\\\Debug\\\\cpp\\\\cassette.exe",
    "rrun:win": "cmd /c build\\\\Release\\\\cpp\\\\cassette.exe",
    "drun:mac": "./build/Debug/cpp/cassette",
    "rrun:mac": "./build/Release/cpp/cassette",
    "drun:lin": "./build/Debug/cpp/cassette",
    "rrun:lin": "./build/Release/cpp/cassette",
    "run": "bun run drun",
    "dbr": "bun run dbld && bun run drun",
    "rbr": "bun run rbld && bun run rrun",
    "br": "bun run dbr",
    "typecheck": "tsc --noEmit",
    "typechk": "tsc --noEmit",
    "***": "Generate the TypeScript & C++ types from the Crow IDL definitions",
    "gen": "crow-idl www/Shared/Definitions.ts -c:cpp/ipc/CommonTypes.hpp -t:www/Shared/CommonTypes.ts",
    "*-*": "Helper to do OS-specific things",
    "os": "bun run build/os.ts"
  },
  "dependencies": {
    "@fluentui/react": "^8.125.5",
    "@fluentui/react-components": "^9.73.2",
    "@fluentui/react-icons-mdl2": "^1.4.5",
    "@freik/containers": "^0.4.5",
    "@freik/fluentui-tools": "^1.2.5",
    "@freik/logger": "^0.4.5",
    "@freik/media-core": "^0.16.5",
    "@freik/react-tools": "^0.3.5",
    "@freik/seqnum": "^1.3.5",
    "@freik/sync": "^0.4.5",
    "@freik/typechk": "^0.9.1",
    "jotai": "^2.18.0",
    "jotai-family": "^1.0.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@freik/passable": "^0.2.1",
    "@freik/ts-cpp-tooling": "^0.3.1",
    "@freik/workspace": "^0.6.5",
    "@types/bun": "^1.3.10",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "clang-format": "^1.8.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "typescript": "^5.9.3"
  }
}
